@using Microsoft.AspNetCore.Identity
@using HousingDomain.Models
@inject UserManager<User> UserManager

<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HomeMatch</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrapMorph.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/HousingInfrastructure.styles.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-lg app-navbar mb-4">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">HomeMatch</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">

                    <ul class="navbar-nav me-auto gap-lg-2">
                        <li class="nav-item"><a class="nav-link" asp-controller="Housings" asp-action="Index">Житло</a></li>

                        @if (User.Identity.IsAuthenticated)
                        {
                            var currentUser = await UserManager.GetUserAsync(User);

                           
                            <li class="nav-item">
                                <a class="nav-link text-info" asp-controller="Profiles" asp-action="MyProfile">Мій профіль</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-info" asp-controller="BookingRequests" asp-action="MyBookings">Мої бронювання</a>
                            </li>

                            @if (currentUser?.Role == "ADMIN")
                            {
                                <li class="nav-item dropdown">
                                <li class="nav-item">
                                    <a class="nav-link text-info" asp-controller="Users" asp-action="Index">Користувачі</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-info" asp-controller="BookingRequests" asp-action="Index">Бронювання</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-info" asp-controller="Reviews" asp-action="Index">Відгуки</a>
                                </li>
                                    
                             </li>
                            }
                        }
                    </ul>

                    <ul class="navbar-nav ms-auto">
                        @if (User.Identity.IsAuthenticated)
                        {
                            var currentUser = await UserManager.GetUserAsync(User);
                            var displayName = currentUser?.Name ?? User.Identity.Name;

                            <li class="nav-item">
                                <span class="nav-link text-dark">Привіт, <strong>@displayName</strong>!</span>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="form-inline">
                                    <button type="submit" class="nav-link btn btn-link text-dark" style="border: none; padding: 8px 15px;">Вийти</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Account" asp-action="Register">Реєстрація</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Account" asp-action="Login">Вхід</a>
                            </li>
                        }
                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <div class="container flex-grow-1 pb-4">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="footer py-3 text-center text-muted border-top mt-auto">
        <div class="container">
            &copy; 2026 - HomeMatch - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>