@model HousingDomain.Models.User

@{
    ViewData["Title"] = "Details";
    var compatibility = ViewBag.Compatibility 
    as IEnumerable<HousingInfrastructure.Controllers.UsersController.CompatibilityResult>;
}

@if (Model.Profile == null)
{
    <a asp-controller="Profiles" 
    asp-action="Create" 
    asp-route-userId="@Model.Id">Create Profile</a>
}
else
{
    <a asp-controller="Profiles"
    asp-action="Edit" 
    asp-route-id="@Model.Profile.Id">Edit Profile</a>
}

<h1>Деталі користувача</h1>

<div>
    <h4>User</h4>
    <hr />
    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Email)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(model => model.Email)</dd>
    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Name)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(model => model.Name)</dd>
    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.BirthDate)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(model => model.BirthDate)</dd>
    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Gender)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(model => model.Gender)</dd>
    <dt class="col-sm-3">Хоче бути власником</dt>
    <dd class="col-sm-9">@(Model.WantsToBeOwner ? "Так" : "Ні")</dd>
    <dt class="col-sm-3">Підтверджений власник</dt>
    <dd class="col-sm-9">@(Model.IsOwnerApproved ? "Так" : "Ні")</dd>
    <dt class="col-sm-3">Роль</dt>
    <dd class="col-sm-9">@Model.Role</dd>
    </dl>
</div>

@if (Model.WantsToBeOwner && !Model.IsOwnerApproved)
{
    <form asp-action="ApproveOwner" method="post" class="mb-3">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.Id" />
        <button type="submit" class="btn btn-success">Підтвердити власника (ADMIN)</button>
    </form>
}

@if (Model.Profile != null)
{
    <h4>Сумісність з іншими користувачами</h4>
    @if (compatibility != null && compatibility.Any())
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Користувач</th>
                    <th>Email</th>
                    <th>Сумісність</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in compatibility)
                {
                    <tr>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.UserId">@item.UserName</a>
                        </td>
                        <td>@item.UserEmail</td>
                        <td>@item.Score%</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p>Немає інших профілів для порівняння.</p>
    }
}

<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>