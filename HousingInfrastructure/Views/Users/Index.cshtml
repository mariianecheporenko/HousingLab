@model IEnumerable<HousingDomain.Models.User>

<h1>Користувачі</h1>

<div class="table-responsive">
    <table class="table">
        <thead>
            <tr>
                <th>Ім'я</th>
                <th>Email</th>
                <th>Роль</th>
                <th>Хоче бути власником</th>
                <th>Статус власника</th>
                <th>Дії</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.Email</td>
                    <td class="@(item.Role == "ADMIN" ? "text-danger fw-bold" : "text-primary")">
                        @item.Role
                    </td>
                    <td>@(item.WantsToBeOwner ? "Так" : "Ні")</td>
                    <td class="@(item.IsOwnerApproved ? "text-success" : (item.WantsToBeOwner ? "text-warning" : "text-muted"))">
                        @(item.WantsToBeOwner ? (item.IsOwnerApproved ? "Підтверджено" : "Очікує") : "-")
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                        <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                        <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>