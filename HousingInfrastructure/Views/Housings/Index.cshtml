@model IEnumerable<HousingDomain.Models.Housing>
@using Microsoft.AspNetCore.Identity
@using HousingDomain.Models
@inject UserManager<User> UserManager

@{
    ViewData["Title"] = "Каталог помешкання";

    User? currentUser = null;
    int? currentUserId = null;
    bool isAdmin = false;

    if (User.Identity?.IsAuthenticated == true)
    {
        currentUser = await UserManager.GetUserAsync(User);
        currentUserId = currentUser?.Id;
        isAdmin = currentUser?.Role == "ADMIN";
    }
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
    <div>
        <h1 class="h2 mb-0">Каталог помешкання</h1>
        <p class="text-muted mb-0">Вибирай житло як ідеальний метч.</p>
    </div>

    @if (currentUser != null && currentUser.WantsToBeOwner && currentUser.IsOwnerApproved)
    {
        <div class="mb-3 mb-md-0">
            <a asp-action="Create" class="btn btn-success shadow-sm">
                <i class="bi bi-plus-circle"></i> Додати нове житло
            </a>
        </div>
    }
</div>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Доступне житло</h2>

    @if (currentUser != null)
    {
        <div class="col-auto">
            <a asp-action="Index" asp-route-userId="@currentUserId" class="btn btn-warning fw-bold shadow-sm">
                ✨ Підібрати найкращі варіанти для мене
            </a>
            @if (Context.Request.Query.ContainsKey("userId"))
            {
                <a asp-action="Index" class="btn btn-link text-secondary text-decoration-none">Скинути розумне сортування</a>
            }
        </div>
    }
</div>

<div class="housing-grid">
    @foreach (var item in Model)
    {
        <article class="housing-card p-3 border rounded shadow-sm mb-3">
            <div class="d-flex justify-content-between align-items-start mb-2 gap-2">
                <h2 class="h5 mb-0">@item.Address</h2>
                <span class="status-pill @(item.IsAvailable == true ? "status-open text-success fw-bold" : "status-closed text-danger fw-bold")">
                    @(item.IsAvailable == true ? "Вільно" : "Зайнято")
                </span>
            </div>

            <p class="text-muted mb-2">📍 @(string.IsNullOrWhiteSpace(item.City) ? "Місто не вказано" : item.City)</p>
            <p class="mb-2">@item.Description</p>

            <ul class="housing-meta list-unstyled mb-3">
                <li><strong>@(item.Price?.ToString("0.##") ?? "—")</strong> грн</li>
                <li><strong>@(item.Rooms?.ToString() ?? "—")</strong> кімнат(и)</li>
                <li><strong>@(item.Area?.ToString("0.##") ?? "—")</strong> м²</li>
                <li>Власник: <strong>@(item.Owner?.Name ?? "Не вказано")</strong></li>
            </ul>

            @{
                var today = DateOnly.FromDateTime(DateTime.Today);
                var occupiedSlots = item.BookingRequests?.Count(b => b.DateFrom <= today && b.DateTo >= today) ?? 0;
                var freeSlots = (item.Rooms ?? 0) - occupiedSlots;
            }

            <p class="card-text mb-3">
                <strong>Вільних місць:</strong>
                <span class="badge @(freeSlots > 0 ? "bg-success" : "bg-danger")">
                    @(freeSlots > 0 ? freeSlots.ToString() : "Місць немає")
                </span>
            </p>

            @{
                bool canEdit = currentUser != null && (item.OwnerId == currentUserId || isAdmin);
            }
            <div class="mt-auto pt-3 border-top d-flex gap-2">
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info @(canEdit ? "flex-fill" : "w-100")">Деталі</a>

                @if (canEdit)
                {
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary flex-fill">Редагувати</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger flex-fill">Видалити</a>
                }
            </div>
        </article>
    }
</div>