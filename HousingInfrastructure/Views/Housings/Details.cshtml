@model HousingDomain.Models.Housing

@{
    ViewData["Title"] = "Details";
}

<h1>Деталі</h1>

<div>
    <h4>Житло</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Address)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Address)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.City)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.City)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Price)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Price)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Rooms)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Rooms)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Area)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Area)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.IsAvailable)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.IsAvailable)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Description)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Description)
        </dd>
        <dt class="col-sm-2">
            Власник
        </dt>
        <dd class="col-sm-10">
            @Model.Owner?.Name
        </dd>
    </dl>
</div>

<h3>Booking Requests</h3>

@if (Model.BookingRequests.Any())
{
    <ul>
        @foreach (var request in Model.BookingRequests)
        {
            <li>
                @request.User.Name (@request.User.Email)
            </li>
        }
    </ul>
}
else
{
    <p>No requests yet.</p>
}

<a asp-controller="BookingRequests"
   asp-action="Create"
   asp-route-housingId="@Model.Id"
   class="btn btn-primary">
    Забронювати
</a>

<hr />

<h3>Відгуки</h3>
@if (User.Identity != null && User.Identity.IsAuthenticated)
{
    <a asp-controller="Reviews"
       asp-action="Create"
       asp-route-housingId="@Model.Id"
       class="btn btn-success mb-3">
        Залишити відгук
    </a>
}
else
{
    <p>
        <a asp-area="Identity" asp-page="/Account/Login">
            Увійдіть
        </a>
        щоб залишити відгук
    </p>
}

@if (Model.Reviews != null && Model.Reviews.Any())
{
    foreach (var review in Model.Reviews)
    {
        <div class="card mb-3 p-3">
            <b>@review.User?.Name</b>
            <br />

            Рейтинг: @review.Rating
            <br />

            @review.Comment
        </div>
    }
}
else
{
    <p>Ще немає відгуків.</p>
}

<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>
