@model HousingDomain.Models.Housing

@{
    ViewData["Title"] = "Редагування помешкання";
}

<section class="romance-form-card">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
        <div>
            <h1 class="h3 mb-1">Редагування житла</h1>
            <p class="text-muted mb-0">Онови параметри профілю помешкання.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">До каталогу</a>
    </div>

    <form asp-action="Edit" class="row g-3">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="col-md-6">
            <label asp-for="Address" class="form-label"></label>
            <input asp-for="Address" class="form-control" />
            <span asp-validation-for="Address" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="City" class="form-label"></label>
            <input asp-for="City" class="form-control" list="cities-list" placeholder="Почніть вводити місто" />
            <datalist id="cities-list">
                @foreach (var city in (IEnumerable<string>)ViewBag.Cities)
                {
                    <option value="@city"></option>
                }
            </datalist>
            <span asp-validation-for="City" class="text-danger"></span>
        </div>

        <div class="col-md-4">
            <label asp-for="Price" class="form-label"></label>
            <input asp-for="Price" class="form-control" />
            <span asp-validation-for="Price" class="text-danger"></span>
        </div>

        <div class="col-md-4">
            <label asp-for="Rooms" class="form-label"></label>
            <input asp-for="Rooms" class="form-control" />
            <span asp-validation-for="Rooms" class="text-danger"></span>
        </div>

        <div class="col-md-4">
            <label asp-for="Area" class="form-label"></label>
            <input asp-for="Area" class="form-control" />
            <span asp-validation-for="Area" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="IsAvailable" class="form-label"></label>
            <select asp-for="IsAvailable" class="form-select">
                <option value="">Не вказано</option>
                <option value="true">Доступно</option>
                <option value="false">Недоступно</option>
            </select>
            <span asp-validation-for="IsAvailable" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="OwnerId" class="form-label"></label>
            <select asp-for="OwnerId" class="form-select" asp-items="ViewBag.OwnerId"></select>
            <span asp-validation-for="OwnerId" class="text-danger"></span>
        </div>

        <div class="col-12">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <input type="hidden" asp-for="Id" />
        <div class="col-12">
            <button type="submit" class="btn btn-primary">Зберегти</button>
        </div>
    </form>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
