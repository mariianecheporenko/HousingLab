@model IEnumerable<HousingDomain.Models.Profile>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.NoiseLevel)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.SleepMode)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Pets)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Guests)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CleanLevel)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Smoking)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.PreferredGender)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.User)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.NoiseLevel)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.SleepMode)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Pets)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Guests)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CleanLevel)
            </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Smoking)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.PreferredGender)
                </td>
            <td>
                @Html.DisplayFor(modelItem => item.User.Email)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
