@model IEnumerable<HousingDomain.Models.Housing>

@{
    ViewData["Title"] = "Каталог помешкання";
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
    <div>
        <h1 class="h2 mb-0">Каталог помешкання</h1>
        <p class="text-muted mb-0">Вибирай житло як ідеальний метч.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">Додати житло</a>
</div>
<section class="filter-panel mb-4">
    <form asp-action="Index" method="get" class="row g-2 align-items-end">
        <div class="col-md-6">
            <label for="userId" class="form-label mb-1">Сортувати відносно користувача</label>
            <select id="userId" name="userId" class="form-select" asp-items="ViewBag.UserId">
                <option value="">Загальне сортування</option>
            </select>
            <div class="form-text">Сортує за бронюваннями користувача та сумісністю вподобань із потенційними сусідами.</div>
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary">Застосувати</button>
        </div>
        <div class="col-auto">
            <a asp-action="Index" class="btn btn-outline-secondary">Скинути</a>
        </div>
    </form>
</section>

<div class="housing-grid">
    @foreach (var item in Model)
    {
        <article class="housing-card">
            <div class="d-flex justify-content-between align-items-start mb-2 gap-2">
                <h2 class="h5 mb-0">@item.Address</h2>
                <span class="status-pill @(item.IsAvailable == true ? "status-open" : "status-closed")">
                    @(item.IsAvailable == true ? "Вільно" : "Зайнято")
                </span>
            </div>

            <p class="text-muted mb-2">📍 @(string.IsNullOrWhiteSpace(item.City) ? "Місто не вказано" : item.City)</p>
            <p class="mb-2">@item.Description</p>

            <ul class="housing-meta list-unstyled mb-3">
                <li><strong>@(item.Price?.ToString("0.##") ?? "—")</strong> грн</li>
                <li><strong>@(item.Rooms?.ToString() ?? "—")</strong> кімнати</li>
                <li><strong>@(item.Area?.ToString("0.##") ?? "—")</strong> м²</li>
                <li>Власник: <strong>@(item.Owner?.Name ?? "Не вказано")</strong></li>
            </ul>

            <div class="d-flex gap-2 flex-wrap">
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Профіль помешкання</a>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Редагувати</a>
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Видалити</a>
            </div>
        </article>
    }
</div>