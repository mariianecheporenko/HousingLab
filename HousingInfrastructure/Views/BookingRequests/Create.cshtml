@model HousingDomain.Models.BookingRequest

@{
    ViewData["Title"] = "Нове бронювання";
    var today = DateTime.Now.ToString("yyyy-MM-dd");
    var tomorrow = DateTime.Now.AddDays(1).ToString("yyyy-MM-dd");
}

    <section class="romance-form-card">
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
            <div>
                <h1 class="h3 mb-1">Забронювати вподобане житло</h1>
                <p class="text-muted mb-0">Обери дати заселення.</p>
            </div>
        <a asp-controller="Housings" asp-action="Details" asp-route-id="@ViewBag.HousingId" class="btn btn-outline-secondary">Повернутися до помешкання</a>
    </div>

    <form asp-action="Create" class="row g-3">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="col-md-6">
            <input type="hidden" name="UserId" value="@ViewBag.UserId" />
        </div>

        <div class="col-md-6">
            <input type="hidden" name="housingId" value="@ViewBag.HousingId" />
        </div>

        <div class="form-group mb-3">
            <label asp-for="DateFrom" class="control-label fw-bold">Дата заїзду</label>
            <input asp-for="DateFrom" type="date" class="form-control" value="@today" min="@today" required />
            <span asp-validation-for="DateFrom" class="text-danger"></span>
        </div>

        <div class="form-group mb-4">
            <label asp-for="DateTo" class="control-label fw-bold">Дата виїзду</label>
            <input asp-for="DateTo" type="date" class="form-control" value="@tomorrow" min="@today" required />
            <span asp-validation-for="DateTo" class="text-danger"></span>
        </div>

        <div class="col-12">
            <button type="submit" class="btn btn-primary">Створити бронювання</button>
        </div>
    </form>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
